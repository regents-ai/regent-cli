{
  "name": "@regentlabs/cli",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Regent CLI package for the published regent command.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "regent": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@regentlabs/cli": "^0.1.0",
    "@worldcoin/idkit-core": "^4.0.15",
    "viem": "^2.38.2",
    "zod": "^4.1.11"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  }
}
